            handles.push(thread::spawn(move || {
                for _ in 0..1000 {
                    counter_clone.fetch_add(1);
                }
            }));
        }
        
        for handle in handles {
            handle.join().unwrap();
        }
        
        assert_eq!(counter.load(), 10000);
    }

