        };
        
        let addr = "127.0.0.1:8080".parse().unwrap();
        let mut conn = Connection::new(stream, addr, ConnectionConfig::default(), BufferPool::new());
        
        // First process detects protocol
        match conn.process().unwrap() {
            ConnectionAction::Continue => {},
